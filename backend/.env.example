# --- Banco (Supabase PostgreSQL) ---
# Dashboard: Project Settings → Database → Connection string
#
# DIRECT_URL = conexão direta (porta 5432) — use no runtime do Nest/Prisma
# DATABASE_URL = pooler (porta 6543) — use em `prisma migrate` se o pooler estiver ativo
#
# Substitua [PROJECT_REF], [PASSWORD] e [REGION] pelos valores do SEU projeto ativo.
# O erro "tenant/user postgres.[ref] not found" = projeto pausado, removido ou ref incorreta.

DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# --- Auth ---
JWT_SECRET=dfghjk
JWT_EXPIRATION_TIME=3600

# --- E-mail (recuperação de senha) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS="sua_senha_super_híper_mega_secreta"
EMAIL_FROM_NAME="User Management"
